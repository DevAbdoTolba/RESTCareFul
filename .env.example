# Copy this file to .env. The .env file is gitignored — never commit secrets.
# Anything not set here falls back to the dev defaults in config/settings/base.py.

# --- Django ---
# Generate a real one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-change-me
DEBUG=True
# Comma-separated. Use * in dev only.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database ---
# Default = SQLite at ./db.sqlite3 (no install required). Switch to Postgres with:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=sqlite:///db.sqlite3

# --- CORS (React dev server) ---
# Comma-separated origins allowed to call the API from a browser.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
